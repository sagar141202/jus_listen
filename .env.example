# ============================================
# tuniq Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# --------------------------------------------
# NextAuth.js Configuration (Required)
# --------------------------------------------
# Generate a random string for JWT signing:
# Linux/macOS: openssl rand -base64 32
# Windows: Use a random string generator
NEXTAUTH_SECRET=your-super-secret-key-change-this-in-production
NEXTAUTH_URL=http://localhost:3000

# --------------------------------------------
# Google OAuth Configuration (Optional)
# Required for authentication features
# Get credentials from: https://console.cloud.google.com/
# --------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --------------------------------------------
# Database Configuration (Optional)
# Defaults shown below, change if needed
# --------------------------------------------
POSTGRES_USER=tuniq
POSTGRES_PASSWORD=tuniq
POSTGRES_DB=tuniq

# --------------------------------------------
# Redis Configuration (Optional)
# Default is fine for most setups
# --------------------------------------------
REDIS_URL=redis://redis:6379/0

# --------------------------------------------
# Backend Configuration (Optional)
# Default is fine for most setups
# --------------------------------------------
BACKEND_URL=http://backend:8000

# --------------------------------------------
# YouTube Music Cookie (Optional)
# Paste your browser cookie here for authenticated YTM requests
# Allows access to liked songs, library, etc. from your YTM account
# Instructions: https://ytmusicapi.readthedocs.io/en/latest/setup/browser.html
# --------------------------------------------
YTM_COOKIE=

# --------------------------------------------
# CORS Configuration (Optional)
# For development, localhost:3000 is fine
# --------------------------------------------
CORS_ORIGINS=http://localhost:3000
